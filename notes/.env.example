# GitHub OAuth App 配置
# 在 https://github.com/settings/developers 创建 OAuth App
VITE_GITHUB_CLIENT_ID=your_client_id_here
VITE_GITHUB_CLIENT_SECRET=your_client_secret_here

# GitHub 仓库配置
VITE_GITHUB_OWNER=your_github_username
VITE_GITHUB_REPO=notes
VITE_GITHUB_BRANCH=main
VITE_NOTES_PATH=notes

# 管理员用户名 (逗号分隔)
VITE_ADMIN_USERS=your_github_username
